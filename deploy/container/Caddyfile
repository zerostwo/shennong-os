{
	admin off
	auto_https off
}

:8080 {
	@ide host {$SHENNONG_IDE_HOST:ide.localhost}
	handle @ide {
		@ide_launch path /__shennong/launch
		handle @ide_launch {
			reverse_proxy 127.0.0.1:8081
		}

		@ide_session_proxy path_regexp ide_session_proxy ^/v1/sessions/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}/proxy(?:/.*)?$
		handle @ide_session_proxy {
			reverse_proxy 127.0.0.1:8081
		}

		handle {
			respond 404
		}
	}

	handle {
		reverse_proxy 127.0.0.1:3000
	}

	log {
		output stdout
		format filter {
			request>uri query {
				replace ticket REDACTED
			}
			wrap json
		}
	}
}
