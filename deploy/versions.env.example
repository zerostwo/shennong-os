# Shennong V1 deployment rollback record. Copy this file to
# /srv/shennong.one/versions.env after deployment and replace every REPLACE_ME
# value with the exact committed revision and deployed image digest or image ID.
# This file is an operator record; do not pass it to Docker Compose as an env file.
# All three repositories start at 1.0.0, but their later versions advance
# independently; never infer one component's version from another component.
SHENNONG_RELEASE_DATE=2026-07-18

SHENNONG_OS_VERSION=1.0.0
SHENNONG_OS_TAG=v1.0.0
SHENNONG_OS_COMMIT=REPLACE_ME
SHENNONG_OS_IMAGE=zerostwo/shennong-os@sha256:REPLACE_ME

SHENNONG_DB_VERSION=1.0.0
SHENNONG_DB_TAG=v1.0.0
SHENNONG_DB_COMMIT=REPLACE_ME
SHENNONG_DB_IMAGE=zerostwo/shennong-db@sha256:REPLACE_ME

SHENNONG_RUNTIME_VERSION=1.0.0
SHENNONG_RUNTIME_TAG=v1.0.0
SHENNONG_RUNTIME_COMMIT=REPLACE_ME
SHENNONG_RUNTIME_IMAGE=zerostwo/shennong-runtime@sha256:REPLACE_ME
