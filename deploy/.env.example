# Everything is optional for a localhost deployment.
SHENNONG_PORT=18081
SHENNONG_DATA_DIR=./shennong-data
SHENNONG_DOCKER_SOCKET=/var/run/docker.sock

# Set these only when the browser uses a non-localhost hostname.
# SHENNONG_PUBLIC_ORIGIN=https://shennong.example.com
# SHENNONG_IDE_PUBLIC_ORIGIN=https://ide.shennong.example.com
# SHENNONG_IDE_HOST=ide.shennong.example.com
# SHENNONG_OS_COOKIE_SECURE=true

# Optional immutable image overrides for production rollback.
# SHENNONG_OS_IMAGE=zerostwo/shennong-os@sha256:...
# SHENNONG_DB_IMAGE=zerostwo/shennong-db@sha256:...
# SHENNONG_RUNTIME_IMAGE=zerostwo/shennong-runtime@sha256:...
