SHENNONG_PUBLIC_BIND=0.0.0.0
SHENNONG_PUBLIC_PORT=18081
SHENNONG_PUBLIC_ORIGIN=http://127.0.0.1:18081
SHENNONG_IDE_PUBLIC_ORIGIN=http://ide.127.0.0.1.nip.io:18081
SHENNONG_IDE_HOST=ide.127.0.0.1.nip.io
SHENNONG_OS_COOKIE_SECURE=false
SHENNONG_MAX_UPLOAD_BYTES=53687091200
SHENNONG_UPLOAD_TIMEOUT_SECONDS=14400

# Application images default to the public zerostwo/*:latest repositories.
# For reproducible production upgrades, optionally set the seven
# SHENNONG_*_IMAGE variables documented in README.md to immutable digests.

SHENNONG_RUNTIME_UID=1002
SHENNONG_RUNTIME_GID=1002
SHENNONG_SECRETS_GID=1003
SHENNONG_ROOTLESS_DOCKER_SOCKET=/run/user/1002/shennong-runtime-docker/docker.sock
SHENNONG_ROOTLESSKIT_STATE_DIR=/run/user/1002/shennong-runtime-rootlesskit
